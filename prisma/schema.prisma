generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(visitor)
  tourGuide TourGuide?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  visitor
  guide
  admin
}

model TourGuide {
  id               String   @id @default(uuid())
  cnpj             String
  legalRepresentativeCpf String
  name             String
  email            String?
  phone            String?
  licenseNumber    String?
  languages        String?
  address          String?
  active           Boolean  @default(true)
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  tokenId          String?  @unique
  tokenHash        String?
  tokenCreatedAt   DateTime?
  schedules        TourGuideAvailability[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TourGuideAvailability {
  id           String     @id @default(uuid())
  tourGuideId  String
  tourGuide    TourGuide  @relation(fields: [tourGuideId], references: [id])
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

model TourGroup {
  id                 String   @id @default(uuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  contractorName     String
  contractorDocument String
  passport           String?
  address            String
  nationality        String?
  contactPerson      String
  transportType      String
  transportModel     String
  transportColor     String
  licensePlate       String
  driverName         String
  driverContact      String
  language           String
  destination        String
  serviceDate        DateTime
  meetingPoint       String
  departureTime      String
  returnEstimate     String
  accommodation      String
  dayTrip            Boolean
  arrivalDate        DateTime
  returnDate         DateTime
  passengerCount     Int
  profile            String
  status             TourGroupStatus @default(pending)
  guideId            String?
}

enum TourGroupStatus {
  pending
  guide_linked
}
