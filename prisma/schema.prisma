generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(visitor)
  tourGuide TourGuide?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  visitor
  guide
  admin
}

model TourGuide {
  id               String   @id @default(uuid())
  cnpj             String
  legalRepresentativeCpf String
  name             String
  email            String?
  phone            String?
  licenseNumber    String?
  languages        String?
  address          String?
  active           Boolean  @default(true)
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  tokenId          String?  @unique
  tokenHash        String?
  tokenCreatedAt   DateTime?
  schedules        TourGuideAvailability[]
  adhesions        TourGuideAdhesion[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TourGuideAvailability {
  id           String     @id @default(uuid())
  tourGuideId  String
  tourGuide    TourGuide  @relation(fields: [tourGuideId], references: [id])
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

model TourGroup {
  id                 String   @id @default(uuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  contractorName     String
  contractorDocument String
  passport           String?
  address            String
  nationality        String?
  contactPerson      String
  transportType      String
  transportModel     String
  transportColor     String
  licensePlate       String
  driverName         String
  driverContact      String
  language           String
  destination        String
  serviceDate        DateTime
  meetingPoint       String
  departureTime      String
  returnEstimate     String
  accommodation      String
  dayTrip            Boolean
  arrivalDate        DateTime
  returnDate         DateTime
  passengerCount     Int
  profile            String
  status             TourGroupStatus @default(pending)
  guideId            String?
}

enum TourGroupStatus {
  pending
  guide_linked
}

model TourGuideAdhesion {
  id           String   @id @default(uuid())
  guideId      String
  tourGuide    TourGuide @relation(fields: [guideId], references: [id])
  adhesionDate DateTime
  validityDate DateTime
  paymentDate  DateTime?
  paymentStatus String  @default("pending")
  amount       Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Commission {
  id           String   @id @default(uuid())
  guideId      String
  guideName    String
  percentage   Float
  effectiveDate DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  document  String
  address   String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmergencyContact {
  id        String   @id @default(uuid())
  guideId   String
  guideName String
  name      String
  relationship String
  phone     String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id         String   @id @default(uuid())
  targetId   String
  targetType String
  type       String
  title      String
  description String
  status     String   @default("new")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Warning {
  id        String   @id @default(uuid())
  guideId   String
  guideName String
  reason    String
  description String
  severity  String
  issuedBy  String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RotationQueueEntry {
  id        String   @id @default(uuid())
  guideId   String   @unique
  guideName String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Penalty {
  id        String   @id @default(uuid())
  guideId   String
  guideName String
  reason    String
  description String
  type      String
  amount    Float?
  duration  Int?
  startDate DateTime
  endDate   DateTime
  status    String
  issuedBy  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
